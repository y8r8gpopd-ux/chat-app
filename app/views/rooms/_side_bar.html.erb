<div class="side_wrapper"> 

  <div class="side_header">
   
    <%= link_to current_user.name, edit_user_path(current_user), class: 'user_name'%> 
    
    <%= link_to 'チャットを作成する', 'rooms/new', class: "create-room" %>
  </div>

  
  

  
  <div class="side_bar">
   <% current_user.rooms.each do |room| %>
    <div class="room">
      <div class="room-name">
        <%= link_to room.name, room_messages_path(room) %>
      </div>
    </div>
  <% end %>
  </div>





</div>